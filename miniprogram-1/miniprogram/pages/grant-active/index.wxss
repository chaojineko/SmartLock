page {
  background: #f7f8fa;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lock {
  color: #223344;
  font-size: 28rpx;
  font-weight: 600;
}

.remain {
  color: #1f5aa2;
  font-size: 24rpx;
}

.qr {
  width: 320rpx;
  height: 320rpx;
  margin: 14rpx auto;
}

.qr-fallback {
  width: 320rpx;
  height: 320rpx;
  margin: 14rpx auto;
  border: 2rpx dashed #c5d0db;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a8794;
}

.meta {
  color: #5b6a7a;
  font-size: 23rpx;
  margin-top: 8rpx;
}

.token {
  word-break: break-all;
}

.danger {
  margin-top: 14rpx;
  background: #c7372f;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 26rpx;
}
