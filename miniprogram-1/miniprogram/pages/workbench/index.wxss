page {
  background: #f7f8fa;
}

.page {
  padding: 24rpx;
}

.tip {
  color: #58687a;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.actions {
  margin-bottom: 20rpx;
}

.ble-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid #d8e2ef;
}

.ble-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1d2f45;
}

.ble-desc {
  display: block;
  margin-top: 8rpx;
  color: #5f7083;
  font-size: 24rpx;
}

.ble-btn {
  margin-top: 14rpx;
  background: #146c43;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.ble-status {
  display: block;
  margin-top: 10rpx;
  color: #36526f;
  font-size: 24rpx;
}

.primary {
  background: #1f5aa2;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.secondary {
  margin-top: 10rpx;
  background: #eef2f7;
  color: #2a3a4a;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 18rpx;
  margin-bottom: 14rpx;
}

.title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #243548;
}

.desc {
  display: block;
  margin-top: 8rpx;
  color: #617286;
  font-size: 24rpx;
}
